{
  "name": "storybook-workshop",
  "version": "0.1.0",
  "description": "Personalized AI-generated children's picture-book product. Build-a-Bear-style ritual workshop; on-device CLIP pillar-match; Pixar 7-beat narrative; Lulu Direct print + ship.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grantalope/storybook-workshop"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "gates": "node scripts/gates/run-all.mjs",
    "validate": "node scripts/validation/capture-defects.mjs"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "jszip": "3.10.1",
    "onnxruntime-web": "^1.22.0",
    "pdf-lib": "1.17.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/svelte": "^5.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/runner": "^4.1.4",
    "@vitest/utils": "^4.1.4",
    "@xenova/transformers": "^2.17.2",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^29.1.0",
    "pngjs": "^7.0.0",
    "svelte": "^5.55.4",
    "svelte-check": "^3.6.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
